# FAB agent (required for LLM tagging stages)
FAB_AGENT_URL=
FAB_IMPROVE_AGENT_URL=
FAB_USER_ID=
FAB_WORKSPACE_ID=
FAB_API=

# Optional: protect /api/* endpoints (leave empty for local dev)
TAGFORGE_API_KEY=

# Optional: restrict CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Hybrid pipeline (all default to true) ─────────────────────────────────────
# USE_RULE_EXTRACTION=true
# USE_RULE_ROUTER=true
# USE_ESRS_LOOKUP=true
# USE_EVIDENCE_WINDOWS=true
# USE_PIPELINE_CACHE=true
# RULE_ROUTER_MIN_SCORE=2.0
# RULE_ROUTER_MIN_MARGIN=1.0
# PARALLEL_FAMILY_WORKERS=4
# MAX_BODY_CHARS=8000
# MAX_EVIDENCE_WINDOW_CHARS=1200

# If TAGFORGE_API_KEY is set, configure the UI before loading the app:
# window.__TAGFORGE_API_KEY__ = "your-key-here";
